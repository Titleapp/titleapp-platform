  "_enforcement": {
    "status": "design_doc",
    "note": "This file is the authoritative design contract, NOT runtime-enforced middleware. Routes in index.js do not check this registry before executing. Enforcement target: capabilities-as-middleware in a future phase. Until then, this file serves as the human-readable permission matrix and drift tracker.",
