  "principles": {
    "no_undeclared_endpoints": "INTENT — every API route should map to a declared capability here. Currently descriptive, not enforced.",
    "chat_and_web_parity": "INTENT — chat and UI should have access to the same capability set.",
    "audit_and_event_required": "ENFORCED — emitsEvent/writesAudit fields are accurate per implementation.",
    "permission_matrix_is_source_of_truth": "INTENT — callers/roles/kyc declared here should match route guards in index.js.",
    "lego_model_add_only": "ENFORCED — never silently modify an existing capability id; create v2."
  },
