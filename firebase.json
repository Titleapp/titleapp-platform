{
  "hosting": {
    "public": "apps/business/dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      { "source": "/auth/google-drive-callback", "destination": "/auth/google-drive-callback.html" },
      { "source": "/auth/shopify-callback", "destination": "/auth/shopify-callback.html" },
      { "source": "/track", "function": { "functionId": "api", "region": "us-central1" } },
      { "source": "/unsub", "function": { "functionId": "api", "region": "us-central1" } },
      { "source": "**", "destination": "/index.html" }
    ],
    "headers": [
      {
        "source": "/assets/**",
        "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
      },
      {
        "source": "/hero/**",
        "headers": [{ "key": "Cache-Control", "value": "no-cache, must-revalidate" }]
      },
      {
        "source": "/illustrations/**",
        "headers": [{ "key": "Cache-Control", "value": "no-cache, must-revalidate" }]
      },
      {
        "source": "/index.html",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
          { "key": "Pragma", "value": "no-cache" }
        ]
      },
      {
        "source": "**/*.html",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
          { "key": "Pragma", "value": "no-cache" }
        ]
      },
      {
        "source": "/",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
          { "key": "Pragma", "value": "no-cache" }
        ]
      },
      {
        "source": "/sw.js",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
        ]
      }
    ]
  },
  "functions": {
    "source": "functions/functions",
    "runtime": "nodejs22",
    "predeploy": [
      "node -e \"const fs=require('fs');fs.mkdirSync('functions/functions/contracts',{recursive:true});fs.copyFileSync('contracts/capabilities.json','functions/functions/contracts/capabilities.json');console.log('[predeploy] synced capabilities.json into function package')\""
    ],
    "ignore": [
      "node_modules",
      ".git",
      "*.log",
      "**/*.bak.*",
      ".env.local",
      ".secret.local",
      "services/copilot/baselines/**/*.pdf"
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  }
}
