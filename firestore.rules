rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin-readable collections (requires authenticated user in admins/ collection)
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Allow admins to read admin-only collections
    match /admins/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /analytics/{docId} {
      allow read: if request.auth != null;
      allow write: if false; // server-only writes
    }

    match /activityFeed/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /accounting/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /config/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /dailyDigest/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /pipeline/{pipelineId}/{subCol}/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /messages/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /draftMessages/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /campaigns/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /ledger/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /payments/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /creatorPayouts/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Users collection — authenticated users can read their own doc, admins can read all
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Workspaces — authenticated users can read their own workspaces
    match /workspaces/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Tenants — the admin console reads these directly via client SDK; business
    // surfaces get tenant data through the API (Admin SDK, which bypasses rules).
    // Surface 1 / R2 (CODEX 2026-06-22): was readable by ANY authenticated user
    // (cross-tenant leak). Scoped to admins to match actual client-SDK usage.
    // If a non-admin client read surfaces, relax to an explicit membership check.
    match /tenants/{tenantId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // RAAS packages
    match /raasPackages/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Memberships — a user may read only their OWN memberships; admins read all.
    // Server writes via Admin SDK bypass these rules. Surface 1 / R2 (CODEX
    // 2026-06-22): was world-readable to any authed user, allowing enumeration
    // of every org's membership roster. No business client reads this directly.
    match /memberships/{docId} {
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if false;
    }

    // Chat messages — user can read/write their own
    match /chatMessages/{docId} {
      allow read, write: if request.auth != null;
    }

    // Message events — authenticated users can read their own conversation history
    match /messageEvents/{docId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if false; // server-only writes
    }

    // Chat sessions — authenticated users can read/write their own conversation history
    match /chatSessions/{docId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // Admin queue — admin only (ID verification, etc.)
    match /adminQueue/{requestId} {
      allow read, write: if isAdmin();
    }

    // Worker sessions — authenticated user, own sessions only
    match /workerSessions/{sessionId} {
      allow read: if request.auth != null && sessionId.matches(request.auth.uid + '_.*');
      allow write: if false; // server-only writes via callable endpoint
    }

    // Workers — authenticated read, owner/admin write for agreement fields
    match /workers/{workerId} {
      allow read: if request.auth != null;
      allow write: if false; // server-only writes
    }

    // Verifications storage paths — write own, read admin only
    // (Storage rules are separate, but Firestore refs to paths follow same pattern)

    // Magic links — server-only writes, no client reads (tokens are sensitive)
    match /magicLinks/{tokenId} {
      allow read, write: if false;
    }

    // Subscriptions — authenticated user can read own subscriptions
    match /subscriptions/{subId} {
      allow read: if request.auth != null && subId.matches(request.auth.uid + '_.*');
      allow write: if false; // server-only writes
    }

    // Suites — authenticated read, server-only write
    match /suites/{suiteId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Worker catalog — public read. The catalog is the public face of the
    // platform (marketplace browse, /workers landing pages, campaign pages
    // are all unauthenticated surfaces). Same data is already exposed via
    // the public marketplace:search and catalog:byVertical API endpoints.
    // Server-only writes via the worker sync pipeline.
    match /digitalWorkers/{slug} {
      allow read: if true;
      allow write: if false;
    }

    // Worker briefings — read own briefing only (doc id = user uid).
    match /briefings/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // CODEX 50.14 — DTC anchor batches are public-readable. The batch
    // contains a Merkle root and ordered leaves so an external verifier
    // can reconstruct the proof for any DTC in the batch. The leaves
    // themselves are content hashes, not record content — they reveal
    // nothing beyond the existence of N records on a given day. Server-
    // only writes (the daily anchor scheduler).
    match /dtcAnchorBatches/{batchId} {
      allow read: if true;
      allow write: if false;
    }

    // Catch-all: deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
