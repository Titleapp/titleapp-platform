{
  "name": "@titleapp/sdk",
  "version": "0.1.0",
  "description": "JavaScript SDK for the TitleApp Digital Worker platform",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
