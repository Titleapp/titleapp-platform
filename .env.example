# SOCIII Platform — Environment Variable Reference
#
# Copy this file to .env (and to functions/functions/.env for backend),
# then fill in the values for the services you have credentials for.
#
# Marked REQUIRED variables are needed for the platform to run end-to-end.
# Marked OPTIONAL variables enable specific workers or features.
#
# NEVER commit .env (it's in .gitignore). Only commit this .env.example.

# =============================================================================
# AI MODEL PROVIDERS — at least one is REQUIRED
# =============================================================================
ANTHROPIC_API_KEY=                       # REQUIRED for Claude-routed chat. Get at console.anthropic.com
OPENAI_API_KEY=                          # OPTIONAL — fallback for OpenAI-routed chat

# =============================================================================
# FIREBASE / GCP — REQUIRED for backend
# =============================================================================
# Most Firebase config is set via gcloud + firebase CLI, not env vars.
# These are the ones that DO need to be set:
STORAGE_BUCKET=                          # REQUIRED — Firebase Storage bucket name (e.g., title-app-alpha.appspot.com)
GDRIVE_ENCRYPTION_KEY=                   # REQUIRED — 32-byte hex key for Drive document encryption at rest

# =============================================================================
# STRIPE — REQUIRED for any worker that handles money or subscriptions
# =============================================================================
STRIPE_SECRET_KEY=                       # REQUIRED — sk_test_... or sk_live_...
STRIPE_PUBLISHABLE_KEY=                  # REQUIRED on client side via VITE_ as well
STRIPE_WEBHOOK_SECRET=                   # REQUIRED for the Stripe webhook endpoint
STRIPE_SOCIII_KEY=                       # Stripe Connect / OAuth-on-behalf-of platform key
STRIPE_PRICE_PILOT_PRO_MONTH=            # Specific Stripe Price ID for the Pilot Pro monthly plan

# =============================================================================
# SENDGRID — REQUIRED for outbound email (advisor invites, investor outreach, magic links)
# =============================================================================
SENDGRID_API_KEY=                        # REQUIRED — SG.xxxx

# =============================================================================
# TWILIO — REQUIRED for SMS (worker notifications, MFA, A2P 10DLC compliance)
# =============================================================================
TWILIO_ACCOUNT_SID=                      # REQUIRED — AC...
TWILIO_AUTH_TOKEN=                       # REQUIRED — auth token
TWILIO_FROM_NUMBER=                      # REQUIRED — +1XXXXXXXXXX (A2P-registered number)

# =============================================================================
# DROPBOX SIGN (HelloSign) — REQUIRED for any worker that produces signed docs
# =============================================================================
HELLOSIGN_API_KEY=                       # REQUIRED — your DBX Sign API key
HELLOSIGN_CLIENT_ID=                     # REQUIRED — your DBX Sign client app id
HELLOSIGN_TEST_MODE=true                 # OPTIONAL — set false for production signing

# =============================================================================
# GOOGLE WORKSPACE OAUTH — REQUIRED for Calendar / Gmail / Drive connectors
# =============================================================================
GOOGLE_OAUTH_CLIENT_ID=                  # REQUIRED — from Google Cloud Console OAuth consent screen
GOOGLE_OAUTH_CLIENT_SECRET=              # REQUIRED
GOOGLE_OAUTH_REDIRECT_URI=               # REQUIRED — typically https://<your-domain>/auth/google/callback

# =============================================================================
# APOLLO — OPTIONAL: enables lead-gen / contact-enrichment workers
# =============================================================================
APOLLO_API_KEY=                          # OPTIONAL — at apollo.io/settings/integrations

# =============================================================================
# FAL.AI — OPTIONAL: enables image generation (Brand Voice Studio, character avatars)
# =============================================================================
FAL_API_KEY=                             # OPTIONAL — fal.run keys

# =============================================================================
# UNIFIED.TO — OPTIONAL: enables LinkedIn auto-posting (Marketing Worker)
# =============================================================================
UNIFIED_API_KEY=                         # OPTIONAL
UNIFIED_WORKSPACE_ID=                    # OPTIONAL

# =============================================================================
# CROSSMINT — DEPRECATED: pre-Coinbase migration path. Use Coinbase Business
# wallet integration (CODEX S52.15 audit-trail architecture) for new builds.
# =============================================================================
CROSSMINT_SERVER_API_KEY=                # OPTIONAL — pre-Coinbase audit anchor
CROSSMINT_COLLECTION_ID=                 # OPTIONAL
CROSSMINT_RECIPIENT=                     # OPTIONAL

# =============================================================================
# SOCIII PUBLIC URL CONFIG — REQUIRED if you're running a branded deployment
# =============================================================================
SOCIII_APP_BASE_URL=https://sociii.ai    # Your platform base URL
SOCIII_DATA_ROOM_URL=                    # Public data room URL (investor flow)
SOCIII_INVESTOR_DECK_URL=                # Public investor deck URL
SOCIII_WHITEPAPER_URL=                   # Public whitepaper URL
SOCIII_CREATOR_GUIDE_URL=                # Public creator-onboarding guide

# =============================================================================
# SOCIII IR CONFIG — REQUIRED for IR worker outbound communications
# =============================================================================
SOCIII_IR_CONTACT_EMAIL=ir@sociii.ai
SOCIII_IR_CONTACT_NAME=                  # Display name in IR outreach emails
SOCIII_IR_CONTACT_ROLE=                  # e.g., "Investor Relations"
SOCIII_IR_CONTACT_FROM_LABEL=            # e.g., "SOCIII IR <ir@sociii.ai>"

# =============================================================================
# SOCIII COMPANY SIGNER (DBX Sign Counterparty for outbound contracts)
# =============================================================================
SOCIII_COMPANY_SIGNER_EMAIL=             # Email of the SOCIII signer (e.g., sean@sociii.ai)
SOCIII_COMPANY_SIGNER_NAME=              # "Sean Lee Combs" (per naming rule)
SOCIII_COMPANY_SIGNER_USER_ID=           # Firebase UID of the signer for audit anchoring

# =============================================================================
# DEBUG / FEATURE FLAGS — OPTIONAL
# =============================================================================
CONTROL_CENTER_DATA_MODE=live            # OPTIONAL — "live" or "demo"
DEBUG_AUTH=false                         # OPTIONAL — verbose auth logging
SIMULATE_ID_VERIFY=false                 # OPTIONAL — skip Stripe Identity gate (dev only)
AUTO_KENT_DEBUG=false                    # OPTIONAL — Kent-flow dev shortcut
OFFICE_HOURS_BOOKING_URL=                # OPTIONAL — booking URL once native scheduler ships

# =============================================================================
# CLIENT-SIDE (VITE_) — these are PUBLIC by design (shipped in client JS bundle)
# Place these in apps/business/.env (not in the backend .env)
# =============================================================================
# VITE_API_BASE=https://titleapp-frontdoor.titleapp-core.workers.dev
# VITE_GOOGLE_MAPS_API_KEY=             # Public Maps key — restricted to your domain in GCP Console
# VITE_CREATOR_SPOTLIGHT_ENABLED=true   # Feature flag

# =============================================================================
# CODE BOT (internal) — NOT NEEDED for fresh forks
# =============================================================================
# CODE_BOT_TOKEN=                       # Internal CI token; do not set

# =============================================================================
# Runtime-only vars (NOT user-configurable — set by the runtime itself)
# =============================================================================
# TENANT, TENANT_ID, USER_EMAIL, USER_UID, ROLE — set per request from auth context
# SMOKE_* — set by smoke-test scripts only
