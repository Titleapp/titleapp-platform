rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // No public or unauthenticated reads anywhere
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // User personal storage — owner only
    match /users/{uid}/personal/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // User business storage — owner + org members (server-side enforced)
    match /users/{uid}/business/{orgId}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Shared storage — explicit access (server-side enforced via signed URLs)
    match /users/{uid}/shared/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Existing tenant document paths (documentEngine)
    match /tenants/{tenantId}/documents/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
